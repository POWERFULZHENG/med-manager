# ======================================
# 数据库配置
# ======================================
DB_ROOT_PASSWORD=MedManager@Root2024
DB_NAME=med_manager
DB_USERNAME=med_user
DB_PASSWORD=MedManager@2024

# ======================================
# JWT 配置
# ======================================
JWT_SECRET=your-super-secret-jwt-key-at-least-256-bits-long-please-change-this

# ======================================
# 邮件服务配置
# ======================================
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your-email@qq.com
MAIL_PASSWORD=your-email-authorization-code
MAIL_FROM=your-email@qq.com

# ======================================
# OCR 服务配置 (百度智能云)
# ======================================
OCR_ENABLED=true
OCR_BAIDU_API_KEY=your-baidu-api-key
OCR_BAIDU_SECRET_KEY=your-baidu-secret-key

# ======================================
# 文件上传配置
# ======================================
UPLOAD_PATH=./upload
UPLOAD_MAX_SIZE=10MB

# ======================================
# Redis 配置
# ======================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ======================================
# 过期提醒配置
# ======================================
EXPIRE_REMINDER_ENABLED=true
EXPIRE_REMINDER_DAYS=30,7,1
